# ─── Market Data ────────────────────────────────────────────────────────────
# Options: finnhub | alpha-vantage | mock (default: mock)
MARKET_DATA_PROVIDER=mock

# Finnhub — free tier: 60 req/min — https://finnhub.io
FINNHUB_API_KEY=

# Alpha Vantage — free tier: 5 req/min — https://alphavantage.co
ALPHA_VANTAGE_API_KEY=

# ─── Research & News ─────────────────────────────────────────────────────────
# Options: perplexity | tavily | mock (default: mock)
RESEARCH_PROVIDER=mock

# Perplexity — https://docs.perplexity.ai
PERPLEXITY_API_KEY=

# Tavily — https://tavily.com
TAVILY_API_KEY=

# ─── AI Analysis ─────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model for report generation (default: claude-haiku-4-5-20251001 for cost efficiency)
# Options: claude-haiku-4-5-20251001 | claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Database (Optional — in-memory store used if not set) ───────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
